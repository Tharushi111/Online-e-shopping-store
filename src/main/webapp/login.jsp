<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login</title>
  <link rel="stylesheet" href="./styles/login.css" />
</head>
<body>
  <div class="container">
    <div class="left-side">
      <img src="images/img1.webp" alt="Login Illustration" />

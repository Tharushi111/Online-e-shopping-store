      <button>Login</button>
      <div class="links">
        <p><a href="forgotPassword.jsp">Forgot password?</a></p>
        <p>Don't have an account? <a href="signup.jsp">Register here</a></p>
      </div>
      <div class="bottom-links">
        <a href="#">Terms of use</a>
        <a href="#">Privacy policy</a>
      </div>
    </div>
  </div>
